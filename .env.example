# Live Location Tracking - Environment Configuration

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Mapbox Configuration (free at https://account.mapbox.com)
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Backend URL (for frontend)
REACT_APP_API_URL=http://localhost:8000

# WebSocket Configuration
WS_URL=ws://localhost:8000

# Auth Token (stored in localStorage, included in WebSocket connections)
REACT_APP_AUTH_TOKEN=your_jwt_token_here
